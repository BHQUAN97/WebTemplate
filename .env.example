# ============================================================================
# WebTemplate — Environment Template
#
# Copy file nay thanh .env (dev) hoac .env.production (prod).
#   cp .env.example .env              # dev
#   cp .env.example .env.production   # prod
#
# Generate secret helpers:
#   JWT/TOTP key:  openssl rand -hex 32
#   DB password:   openssl rand -base64 24
# ============================================================================

# === Domain ===
DOMAIN=example.com
DOMAIN_EMAIL=admin@example.com

# === MySQL ===
# Trong Docker: DB_HOST=mysql (standalone) hoac shared-mysql (shared VPS)
# Local dev khong Docker: DB_HOST=127.0.0.1
DB_HOST=mysql
DB_PORT=3306
DB_NAME=webtemplate
DB_USER=webtemplate
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_STRONGER_ROOT_PASSWORD

# === Redis / BullMQ ===
# Trong Docker: REDIS_HOST=redis | shared-redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

# === JWT (tat ca key >= 32 chars, PHAI khac nhau) ===
# Generate: openssl rand -hex 32
JWT_ACCESS_SECRET=generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=different_from_access_secret
JWT_RESET_SECRET=different_from_both_above
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_RESET_EXPIRES=1h

# === 2FA ===
# Generate: openssl rand -hex 32  (32 bytes = 64 hex chars)
TWO_FACTOR_ENCRYPTION_KEY=64_hex_chars_32_bytes
TOTP_ISSUER=WebTemplate

# === App ===
APP_NAME=WebTemplate
APP_URL=https://example.com
API_URL=https://example.com
APP_PORT=6001
FRONTEND_PORT=6000
NODE_ENV=production
TYPEORM_SYNC=false

# === CORS — cach nhau boi dau phay, ho tro wildcard *.domain.com ===
CORS_ORIGINS=https://example.com,https://www.example.com

# === Sentry (optional) — bo trong de tat ===
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# === Swagger ===
# Chi co hieu luc khi NODE_ENV=production; neu true se expose /api/docs o prod
SWAGGER_ENABLED=false

# === Email (Resend) ===
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@example.com

# === S3 / R2 ===
S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=webtemplate-media
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=https://cdn.example.com

# === OAuth ===
# Chi register strategy khi OAUTH_*_ENABLED=true (de tranh crash khi thieu credentials).
OAUTH_GOOGLE_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:6001/api/auth/google/callback
OAUTH_FACEBOOK_ENABLED=false
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_FACEBOOK_CALLBACK_URL=http://localhost:6001/api/auth/facebook/callback
OAUTH_SUCCESS_REDIRECT=http://localhost:6000/auth/callback
OAUTH_FAILURE_REDIRECT=http://localhost:6000/login?error=oauth
# Legacy — giu tam thoi de tuong thich cu (backend khong con dung)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# === Mail (Resend) — bo sung cho module mail wrapper ===
MAIL_FROM="WebTemplate <noreply@yourdomain.com>"
MAIL_FRONTEND_URL=http://localhost:6000

# === Payment gateways ===
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://example.com/api/payments/callback/vnpay
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Backup ===
# chmod 600 cho file passphrase, mount read-only vao container
BACKUP_GPG_PASSPHRASE_FILE=/secrets/backup.pass
# Hoac dung openssl thay GPG:
# BACKUP_OPENSSL_PASSPHRASE=CHANGE_ME_OPENSSL_PASSPHRASE
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_NOTIFY_WEBHOOK=

# === MySQL Backup (scripts/backup-mysql.sh) ===
# Password cho backup-mysql.sh. Neu trong, script se doc tu DB_PASSWORD o tren.
MYSQL_BACKUP_PASSWORD=

# === Google Drive Backup (optional) ===
# Service Account authentication — see scripts/.gdrive-credentials.example.json
GDRIVE_ENABLED=false
GDRIVE_CREDENTIALS_PATH=./scripts/.gdrive-credentials.json
GDRIVE_FOLDER_ID=
GDRIVE_DB_SUBFOLDER=database
GDRIVE_UPLOADS_SUBFOLDER=media
# Giu N ban moi nhat trong moi subfolder, xoa cu hon
GDRIVE_KEEP_COUNT=14
# Thu muc chua .sql.gz do backup-mysql.sh tao ra
BACKUP_DIR=/opt/webtemplate/backups
# Thu muc uploads cua backend (zip truoc khi upload)
UPLOADS_DIR=./backend/uploads
