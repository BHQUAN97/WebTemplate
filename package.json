{
  "name": "webtemplate-root",
  "version": "0.0.0",
  "private": true,
  "description": "Root workspace orchestration for WebTemplate (husky, lint-staged, CLI generators).",
  "scripts": {
    "prepare": "husky",
    "gen:module": "node scripts/generate-module.js",
    "lint:backend": "npm --prefix backend run lint",
    "lint:frontend": "npm --prefix frontend run lint",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build"
  },
  "lint-staged": {
    "backend/**/*.{ts,js}": [
      "bash -c 'cd backend && eslint --fix'"
    ],
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "bash -c 'cd frontend && eslint --fix'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "engines": {
    "node": ">=20"
  }
}
